{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": true,
    "lib": ["ES2022"],
    "types": ["node"]
  },
  "include": ["src/**/*.js", "test/**/*.js", "scripts/**/*.js"]
}
