{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://alloy.dev/schemas/task-brief.schema.json",
  "title": "Alloy Task Brief",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "task_id",
    "repo",
    "base_ref",
    "mode",
    "providers",
    "judge",
    "max_runtime_minutes",
    "risk_level",
    "human_review_policy",
    "title",
    "requirements",
    "constraints",
    "acceptance_checks"
  ],
  "properties": {
    "task_id": {"type": "string", "minLength": 1},
    "repo": {"type": "string", "minLength": 1},
    "base_ref": {"type": "string", "minLength": 1},
    "mode": {"type": "string", "enum": ["fast", "race", "relay", "committee"]},
    "providers": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "enum": ["codex", "gemini", "claude-code"]}
    },
    "judge": {"type": "string", "enum": ["codex", "gemini", "claude-code"]},
    "max_runtime_minutes": {"type": "integer", "minimum": 1},
    "risk_level": {"type": "string", "enum": ["low", "medium", "high"]},
    "human_review_policy": {"type": "string", "enum": ["minimal", "standard", "strict"]},
    "title": {"type": "string", "minLength": 1},
    "context": {"type": "string"},
    "requirements": {"type": "array", "items": {"type": "string"}},
    "constraints": {"type": "array", "items": {"type": "string"}},
    "acceptance_checks": {"type": "array", "items": {"type": "string"}},
    "optional_guidance": {"type": "array", "items": {"type": "string"}},
    "human_notes": {"type": "array", "items": {"type": "string"}},
    "allowed_paths": {"type": "array", "items": {"type": "string"}},
    "blocked_paths": {"type": "array", "items": {"type": "string"}},
    "tags": {"type": "array", "items": {"type": "string"}},
    "synthesis_policy": {"type": "string", "enum": ["auto", "manual", "winner_only"]},
    "publish_policy": {"type": "string", "enum": ["manual", "auto_if_high_confidence"]},
    "additional_sections": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["heading", "content"],
        "properties": {
          "heading": {"type": "string"},
          "content": {"type": "string"}
        }
      }
    }
  }
}
